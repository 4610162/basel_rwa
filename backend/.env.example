# Google Gemini API Key (required)
GOOGLE_API_KEY=your_google_api_key_here

# ChromaDB 저장 경로 (기본값: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db
# Railway Volume 사용 시, 별도 CHROMA_DB_PATH가 없으면
# RAILWAY_VOLUME_MOUNT_PATH/chroma_db 를 자동 사용합니다.

# 데이터 폴더 경로 (기본값: ./data)
# DATA_DIR=./data

# 청킹 기본값 (기본값: chunk_size=1000, chunk_overlap=150)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150

# 앱 시작 시 RAG 전체 임베딩 워밍업 실행 여부 (배포 환경에서는 보통 false 권장)
# RAG_WARMUP_ON_STARTUP=false

# 임베딩 배치 기본값 (기본값: batch_size=20, sleep_seconds=15)
# EMBEDDING_BATCH_SIZE=20
# EMBEDDING_BATCH_SLEEP_SECONDS=15

# CORS 허용 Origin (기본값: http://localhost:3000)
# CORS_ORIGINS=["http://localhost:3000"]
